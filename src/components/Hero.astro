---
import Figure from './Figure.astro';
import heroImage from '../assets/hero-piston.jpg';

const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <span class="section-kicker">MECHANICAL ENGINEERING PORTFOLIO</span>
      <h1 class="hero-name">Eric Lin</h1>
      <p class="hero-subhead">I design, analyze, and machine real hardware: from CAD and GD&T drawings to parts turned on a manual lathe.</p>
      <p class="hero-target">BS Mechanical Engineering at RIT, graduating May 2027. Interviewing for internship and new-grad roles in aerospace and defense, semiconductors, and oil and gas.</p>
      <div class="hero-buttons">
        <a class="btn btn-primary" href={`${base}#projects`}>View projects</a>
        <a class="btn btn-secondary" href={`${base}resume.pdf`} target="_blank" rel="noopener">Download resume (PDF)</a>
      </div>
    </div>
    <div class="hero-image">
      <Figure
        src={heroImage}
        alt="Photo of the assembled piston/crank mechanism machined on a manual lathe and mill"
        caption="Piston, machined on a manual lathe and mill to a GD&T drawing."
        widths={[480, 720, 1200]}
        sizes="(min-width: 1024px) 420px, 100vw"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--s-9);
    padding-bottom: var(--s-8);
  }
  .hero-grid {
    display: grid;
    gap: var(--s-6);
  }
  .hero-name {
    font-family: var(--font-sans);
    font-size: var(--text-display);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-top: var(--s-2);
  }
  .hero-subhead {
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-2);
    max-width: 34ch;
    margin-top: var(--s-4);
  }
  .hero-target {
    font-size: var(--text-body);
    color: var(--color-text);
    margin-top: var(--s-4);
  }
  .hero-buttons {
    display: flex;
    gap: 12px;
    margin-top: var(--s-5);
    flex-wrap: wrap;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: repeat(12, 1fr);
      gap: 24px;
      align-items: center;
    }
    .hero-text {
      grid-column: 1 / 8;
    }
    .hero-image {
      grid-column: 8 / 13;
    }
  }
</style>
