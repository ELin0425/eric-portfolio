---
const tiles = [
  { label: 'EDUCATION', value: 'BS Mechanical Engineering, RIT, May 2027' },
  { label: 'CAD + ANALYSIS', value: 'SolidWorks, ANSYS, MATLAB, AutoCAD' },
  { label: 'HANDS-ON', value: 'Manual lathe and mill, GD&T, Arduino' },
  { label: 'INDUSTRY', value: 'RMF Engineering, piping and pipe stress' },
];
---

<section class="cred-strip">
  <div class="container cred-grid">
    {tiles.map((t) => (
      <div class="cred-tile">
        <span class="cred-label">{t.label}</span>
        <span class="cred-value">{t.value}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .cred-strip {
    padding-bottom: var(--s-8);
  }
  .cred-grid {
    display: grid;
    grid-template-columns: 1fr;
  }
  .cred-tile {
    padding-block: var(--s-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .cred-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-3);
  }
  .cred-value {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--color-text);
  }

  @media (min-width: 640px) {
    .cred-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0 var(--s-6);
    }
  }

  @media (min-width: 1024px) {
    .cred-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .cred-tile {
      border-top: none;
      border-left: 1px solid var(--color-border);
      padding-inline-start: var(--s-5);
    }
    .cred-tile:first-child {
      border-left: none;
      padding-inline-start: 0;
    }
  }
</style>
