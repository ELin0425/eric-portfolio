---
import { CATEGORY_LABELS } from '../lib/categories';

interface Props {
  categories: { key: string; count: number }[];
}

const { categories } = Astro.props;
---

<div class="project-filter" id="project-filter" role="group" aria-label="Filter projects by category">
  <button type="button" class="chip filter-chip is-active" data-filter="all" aria-pressed="true">All</button>
  {categories.map((c) => (
    <button type="button" class="chip filter-chip" data-filter={c.key} aria-pressed="false">
      {CATEGORY_LABELS[c.key] ?? c.key} ({c.count})
    </button>
  ))}
</div>

<style>
  .project-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    margin-top: var(--s-6);
  }

  .filter-chip {
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease), background-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .filter-chip:hover {
    border-color: var(--color-border-strong);
  }
  .filter-chip.is-active {
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
