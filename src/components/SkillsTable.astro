---
const base = import.meta.env.BASE_URL;

const rows = [
  {
    group: 'CAD and drafting',
    tools: ['SolidWorks', 'Onshape', 'Fusion 360', 'AutoCAD'],
    evidenceHtml: `Part and assembly modeling, drawing packages, and GD&T (see <a href="${base}projects/piston/">Piston</a>); client-iterative design in Fusion 360 (see <a href="${base}projects/watering-hole/">The Watering Hole</a>).`,
  },
  {
    group: 'Plant and piping',
    tools: ['Revit', 'AutoCAD Plant 3D', 'Bentley AutoPIPE'],
    evidenceHtml: 'Utility piping and tunnel models, P&IDs, and pipe stress analysis at RMF Engineering.',
  },
  {
    group: 'Analysis',
    tools: ['ANSYS', 'MATLAB'],
    evidenceHtml: `FEA and scripting from RIT coursework; statics-driven sizing on <a href="${base}projects/mini-catapult/">Mini Catapult</a>.`,
  },
  {
    group: 'Fabrication',
    tools: ['Manual lathe', 'Manual mill', 'GD&T'],
    evidenceHtml: `Machined the <a href="${base}projects/piston/">Piston</a> to its own toleranced drawing and validated the part against CAD.`,
  },
  {
    group: 'Embedded and mechatronics',
    tools: ['Arduino'],
    evidenceHtml: `Solenoid and motor timing control on the <a href="${base}projects/chime-machine/">Chime Machine</a>.`,
  },
];
---

<div class="skills-table">
  {rows.map((row) => (
    <div class="skills-row">
      <div class="skills-group">{row.group}</div>
      <div class="skills-content">
        <div class="skills-chips">
          {row.tools.map((tool) => <span class="chip chip-tool">{tool}</span>)}
        </div>
        <p class="skills-evidence" set:html={row.evidenceHtml} />
      </div>
    </div>
  ))}
</div>

<style>
  .skills-table {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-m);
    overflow: hidden;
  }

  .skills-row {
    display: grid;
    gap: var(--s-3);
    padding: var(--s-5);
  }
  .skills-row + .skills-row {
    border-top: 1px solid var(--color-border);
  }

  .skills-group {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--color-text);
  }

  .skills-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }

  .skills-evidence {
    margin-top: var(--s-3);
    font-size: var(--text-small);
    color: var(--color-text-2);
  }

  @media (min-width: 768px) {
    .skills-row {
      grid-template-columns: 200px 1fr;
    }
  }
</style>
