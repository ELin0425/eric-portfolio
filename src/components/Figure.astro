---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  widths?: number[];
  sizes?: string;
  wide?: boolean;
}

const {
  src,
  alt,
  caption,
  widths = [640, 960, 1600],
  sizes = '(min-width: 1024px) 800px, 100vw',
  wide = false,
} = Astro.props;
---

<figure class:list={['figure', { 'figure-wide': wide }]}>
  <Image src={src} alt={alt} widths={widths} sizes={sizes} format="webp" quality={80} />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin: 0;
  }
  .figure :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-m);
    box-shadow: var(--shadow-1);
  }
  .figure figcaption {
    margin-top: var(--s-2);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-3);
  }
</style>
