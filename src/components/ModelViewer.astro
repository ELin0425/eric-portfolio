---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  model3d: { kind: 'glb' | 'sketchfab'; src: string; poster?: ImageMetadata };
  alt: string;
}

const { model3d, alt } = Astro.props;
const base = import.meta.env.BASE_URL;
const modelSrc = model3d.kind === 'glb' ? `${base}${model3d.src}` : model3d.src;

let posterSrc: string | undefined;
if (model3d.poster) {
  const optimized = await getImage({ src: model3d.poster, format: 'webp', width: 960 });
  posterSrc = optimized.src;
}
---

<div class="model-viewer-wrap">
  {model3d.kind === 'glb' && (
    <model-viewer src={modelSrc} alt={alt} camera-controls poster={posterSrc}>
      <div slot="poster" class="model-poster">
        {posterSrc && <img src={posterSrc} alt="" />}
        <span class="model-poster-label">Loading 3D model</span>
      </div>
    </model-viewer>
  )}

  {model3d.kind === 'sketchfab' && (
    <iframe title={alt} src={model3d.src} allow="autoplay; fullscreen; xr-spatial-tracking" allowfullscreen loading="lazy"></iframe>
  )}
</div>

<script>
  import '@google/model-viewer';
</script>

<style>
  .model-viewer-wrap {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-m);
    border: 1px solid var(--color-border);
    overflow: hidden;
    position: relative;
  }
  model-viewer,
  iframe {
    width: 100%;
    height: 100%;
    display: block;
  }
  .model-poster {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .model-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .model-poster-label {
    position: absolute;
    bottom: var(--s-3);
    left: var(--s-3);
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--color-text-3);
    background: rgba(247, 246, 243, 0.9);
    padding: 4px 10px;
    border-radius: var(--radius-s);
  }
</style>
