---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { CATEGORY_LABELS } from '../lib/categories';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, category, tools, hero, heroAlt, status } = project.data;
const base = import.meta.env.BASE_URL;
const visibleTools = tools.slice(0, 4);
const extraCount = tools.length - visibleTools.length;
---

<a class="card" href={`${base}projects/${project.id}/`} data-category={category} data-reveal-item>
  <div class="card-image">
    <Image src={hero} alt={heroAlt} widths={[400, 600, 800]} sizes="(min-width: 768px) 50vw, 100vw" format="webp" quality={80} />
  </div>
  <div class="card-body">
    <div class="card-top-row">
      <span class="card-category">{CATEGORY_LABELS[category] ?? category}</span>
      {status === 'in-progress' && <span class="card-badge">IN PROGRESS</span>}
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-summary">{summary}</p>
    <div class="card-tools">
      {visibleTools.map((tool) => <span class="chip chip-tool">{tool}</span>)}
      {extraCount > 0 && <span class="chip chip-tool">+{extraCount}</span>}
    </div>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-m);
    box-shadow: var(--shadow-1);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-2);
    border-color: var(--color-border-strong);
  }
  .card[hidden] {
    display: none;
  }
  .card:active {
    transform: translateY(0);
  }

  .card-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .card-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-fast) var(--ease);
  }
  .card:hover .card-image :global(img) {
    transform: scale(1.02);
  }

  .card-body {
    padding: var(--s-5);
  }

  .card-top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s-2);
  }

  .card-category {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }

  .card-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-status-progress);
    background: var(--color-surface-2);
    border-radius: var(--radius-s);
    padding: 2px 8px;
  }

  .card-title {
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-text);
    margin-top: var(--s-3);
  }

  .card-summary {
    font-size: var(--text-small);
    color: var(--color-text-2);
    margin-top: var(--s-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tools {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-3);
  }
</style>
